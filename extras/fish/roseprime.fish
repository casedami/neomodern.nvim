# name: roseprime colors for fish
# url: https://fishshell.com/docs/current/index.html
# upstream: https://github.com/cdmill/neomodern.nvim/raw/main/extras/
# author: Casey Miller

# use in ~/.config/fish/conf.d/

# preferred bg: 141517

### Full palette. 
### Colors defined in neomdern/palette/roseprime.lua
set -g alt A3BDD9
set -g constant 96aff2
set -g comment 6e6a86
set -g fg e0def4
set -g func b197d1
set -g keyword 6591bf
set -g number ebbcba
set -g operator 8E79A7
set -g property c2748b
set -g str c9aa95
set -g type 9bbdb8

# Syntax Highlighting Colors
set -g fish_color_normal e0def4
set -g fish_color_command b197d1
set -g fish_color_keyword 6591bf
set -g fish_color_quote c9aa95
set -g fish_color_redirection 96aff2
set -g fish_color_end 8E79A7
set -g fish_color_error DF7C82
set -g fish_color_param e0def4
set -g fish_color_valid_path 9bbdb8
set -g fish_color_option A3BDD9
set -g fish_color_comment 6e6a86
set -g fish_color_selection --background=1C1D1F
set -g fish_color_operator 8E79A7
set -g fish_color_escape 6591bf
set -g fish_color_autosuggestion 6e6a86
set -g fish_color_cwd c9aa95
set -g fish_color_hostname ebbcba
set -g fish_color_status DF7C82
set -g fish_color_cancel ebbcba
set -g fish_color_search_match --background=1C1D1F

# Completion Pager Colors
set -g fish_pager_color_progress A3BDD9
set -g fish_pager_color_prefix 9bbdb8
set -g fish_pager_color_completion e0def4
set -g fish_pager_color_description 6e6a86
set -g fish_pager_color_selected_prefix A3BDD9
set -g fish_pager_color_selected_completion A3BDD9
set -g fish_pager_color_selected_background --background=1C1D1F
