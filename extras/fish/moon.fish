# name: moon colors for fish
# url: https://fishshell.com/docs/current/index.html
# upstream: https://github.com/cdmill/neomodern.nvim/raw/main/extras/
# author: Casey Miller

# use in ~/.config/fish/conf.d/

# preferred bg: 151515

### Full palette. 
### Colors defined in neomdern/palette/moon.lua
set -g alt C3C3D0
set -g constant b5b3a5
set -g comment 4c4c57
set -g fg A2A2AD
set -g func 626E85
set -g keyword 7a8aa6
set -g number b39066
set -g operator 575D70
set -g property 817882
set -g str 777d77
set -g type 6d748c

# Syntax Highlighting Colors
set -g fish_color_normal A2A2AD
set -g fish_color_command 626E85
set -g fish_color_keyword 7a8aa6
set -g fish_color_quote 777d77
set -g fish_color_redirection b5b3a5
set -g fish_color_end 575D70
set -g fish_color_error DC827B
set -g fish_color_param A2A2AD
set -g fish_color_valid_path 6d748c
set -g fish_color_option C3C3D0
set -g fish_color_comment 4c4c57
set -g fish_color_selection --background=1D1D1D
set -g fish_color_operator 575D70
set -g fish_color_escape 7a8aa6
set -g fish_color_autosuggestion 4c4c57
set -g fish_color_cwd 777d77
set -g fish_color_hostname b39066
set -g fish_color_status DC827B
set -g fish_color_cancel b39066
set -g fish_color_search_match --background=1D1D1D

# Completion Pager Colors
set -g fish_pager_color_progress C3C3D0
set -g fish_pager_color_prefix 6d748c
set -g fish_pager_color_completion A2A2AD
set -g fish_pager_color_description 4c4c57
set -g fish_pager_color_selected_prefix C3C3D0
set -g fish_pager_color_selected_completion C3C3D0
set -g fish_pager_color_selected_background --background=1D1D1D
